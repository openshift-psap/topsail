apiVersion: batch/v1
kind: Job
metadata:
  name: "{{ llmd_run_guidellm_benchmark_name }}"
  namespace: "{{ target_namespace }}"
spec:
  backoffLimit: 0
  template:
    spec:
      serviceAccountName: default
      restartPolicy: Never
      initContainers:
        - name: permission-fixer
          image: "{{ llmd_run_guidellm_benchmark_image }}:{{ llmd_run_guidellm_benchmark_version }}"
          command: ["/bin/sh", "-c"]
          args:
            - |
              echo "Fixing permissions on /results directory..."
              chmod 777 /results
              chown -R 1001:1001 /results || true
              echo "Permissions fixed successfully"
          securityContext:
            runAsUser: 0
            allowPrivilegeEscalation: true
          volumeMounts:
            - name: results
              mountPath: /results
      containers:
        - name: guidellm
          image: "{{ llmd_run_guidellm_benchmark_image }}:{{ llmd_run_guidellm_benchmark_version }}"
          command:
            - /opt/app-root/bin/guidellm
          args:
            - benchmark
            - run
            - --target={{ benchmark_endpoint_url }}
{% for arg in llmd_run_guidellm_benchmark_guidellm_args %}
            - {{ arg }}
{% endfor %}
            - --outputs=json
          env:
            - name: USER # version 0.6.0-pr590 currently needs that ...
              value: guidellm
          securityContext:
            runAsUser: 1001
            runAsNonRoot: true
            allowPrivilegeEscalation: false
          volumeMounts:
            - name: home
              mountPath: /home/guidellm
            - name: results
              mountPath: /results
      volumes:
        - name: home
          emptyDir: {}
        - name: results
          persistentVolumeClaim:
            claimName: "{{ llmd_run_guidellm_benchmark_name }}"
